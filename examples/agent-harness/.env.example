# Copy to .env and `set -a; source .env; set +a` (or export manually).
# Bring your own model + key — set the one for the provider you'll use. The
# gateway holds its own CyberGuard credential and is the sole path into the arena,
# so the harness only needs your model key.

# --provider anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# --provider openai
# OPENAI_API_KEY=sk-...

# --provider deepseek
# DEEPSEEK_API_KEY=sk-...

# --provider gemini  (uses Gemini's OpenAI-compatible endpoint)
# GEMINI_API_KEY=...

# --provider ollama / local  (local models usually need no key)
# LLM_BASE_URL=http://localhost:11434/v1     # or your vLLM/LM Studio endpoint
# LLM_API_KEY=not-needed

# Optional gateway override (CLI --gateway-url takes precedence):
# CYBERGUARD_GATEWAY_URL=http://localhost:9000/mcp
